{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/nicolo/oxfmt-config/npm/oxlint/configuration_schema.json",
  "plugins": ["react", "import", "jsx-a11y"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "globals": {
    "React": "readonly"
  },
  "ignorePatterns": ["dist"],
  "rules": {
    "no-unused-vars": [
      "error",
      { "varsIgnorePattern": "^[A-Z_]" }
    ],
    "react/rules-of-hooks": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/no-direct-mutation-state": "error",
    "react/jsx-key": "error"
  }
}
